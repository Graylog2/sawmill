    "aceEditor": "
 .ace_editor {
    border: 1px solid #dbcdd0;
    border-radius: 5px;
  }

  .ace-graylog {
    background-color: #0b42ff;
    color: #d0d0d0;

    &.ace_multiselect .ace_selection.ace_start {
      box-shadow: 0 0 3px 0 #0b42ff;
    }

    .ace_gutter {
      background: #565656;
      color: #d0d0d0;
    }

    .ace_print-margin {
      width: 1px;
      background: #565656;
    }

    .ace_cursor {
      color: #767676;
    }

    .ace_marker-layer {
      .ace_selection {
        background: #c9bec2;
      }

      .ace_step {
        background: rgb(255 255 0);
      }

      .ace_bracket {
        margin: -1px 0 0 -1px;
        border: 1px solid #c9bec2;
      }

      .ace_selected-word {
        border: 1px solid #b7afb4;
      }

      .ace_active-line {
        background: #676767;
      }
    }

    .ace_gutter-active-line {
      background-color: #676767;
    }

    .ace_invisible {
      color: #c9bec2;
    }

    .ace_keyword,
    .ace_meta,
    .ace_storage,
    .ace_storage.ace_type,
    .ace_support.ace_type {
      color: #8cb5ea;
    }

    .ace_keyword.ace_operator {
      color: #9797ff;
    }

    .ace_constant.ace_character,
    .ace_constant.ace_language,
    .ace_constant.ace_numeric,
    .ace_keyword.ace_other.ace_unit,
    .ace_support.ace_constant,
    .ace_variable.ace_parameter {
      color: #b797b7;
    }

    .ace_constant.ace_other {
      color: #b7b7b7;
    }

    .ace_invalid {
      color: #ffebeb;
      background-color: #eb0000;
    }

    .ace_invalid.ace_deprecated {
      color: #ffebeb;
      background-color: #800080;
    }

    .ace_fold {
      background-color: #0000FF;
      border-color: #d0d0d0;
    }

    .ace_entity.ace_name.ace_function,
    .ace_support.ace_function,
    .ace_variable {
      color: #0000FF;
    }

    .ace_support.ace_class,
    .ace_support.ace_type {
      color: #ffff97;
    }

    .ace_heading,
