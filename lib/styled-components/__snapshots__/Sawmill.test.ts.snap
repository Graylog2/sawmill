        "info": "#9e9eff",
        "primary": "#bb9ebb",
        "success": "#9ebb9e",
        "warning": "#ffff9e",
      },
      "lightest": {
        "danger": "#ffbdbd",
        "default": "#d0d0d0",
        "gray": "#f6f6f6",
        "info": "#bdbdff",
        "primary": "#d0bdd0",
        "success": "#bdd0bd",
        "warning": "#ffffbd",
      },
      "primary": "#800080",
      "success": "#008000",
      "warning": "#FFFF00",
    },
  },
  "components": {
    "aceEditor": "
 .ace_editor {
    border: 1px solid #dbcdd0;
    border-radius: 5px;
  }

  .ace-graylog {
    background-color: #0b42ff;
    color: #565656;

    &.ace_multiselect .ace_selection.ace_start {
      box-shadow: 0 0 3px 0 #0b42ff;
    }

    .ace_gutter {
      background: #d0d0d0;
      color: #565656;
    }

    .ace_print-margin {
      width: 1px;
      background: #d0d0d0;
    }

    .ace_cursor {
      color: #a5a5a5;
    }

    .ace_marker-layer {
      .ace_selection {
        background: #c9bec2;
      }

      .ace_step {
        background: rgb(255 255 0);
      }

      .ace_bracket {
        margin: -1px 0 0 -1px;
        border: 1px solid #c9bec2;
      }

      .ace_selected-word {
        border: 1px solid #b7afb4;
      }

      .ace_active-line {
        background: #bbbbbb;
      }
    }

    .ace_gutter-active-line {
      background-color: #bbbbbb;
    }

    .ace_invisible {
      color: #c9bec2;
    }

    .ace_keyword,
    .ace_meta,
    .ace_storage,
    .ace_storage.ace_type,
    .ace_support.ace_type {
      color: #8cb5ea;
    }

    .ace_keyword.ace_operator {
      color: #0000c8;
    }

    .ace_constant.ace_character,
    .ace_constant.ace_language,
    .ace_constant.ace_numeric,
    .ace_keyword.ace_other.ace_unit,
    .ace_support.ace_constant,
    .ace_variable.ace_parameter {
      color: #640064;
    }

    .ace_constant.ace_other {
      color: #646464;
    }

    .ace_invalid {
      color: #ffebeb;
      background-color: #ff7878;
    }

    .ace_invalid.ace_deprecated {
      color: #ffebeb;
      background-color: #800080;
    }

    .ace_fold {
      background-color: #0000FF;
      border-color: #565656;
    }

    .ace_entity.ace_name.ace_function,
    .ace_support.ace_function,
    .ace_variable {
      color: #0000FF;
    }

    .ace_support.ace_class,
    .ace_support.ace_type {
      color: #c8c800;
    }

    .ace_heading,
    .ace_markup.ace_heading,
    .ace_string {
      color: #006400;
    }

    .ace_entity.ace_name.ace_tag,
    .ace_entity.ace_other.ace_attribute-name,
    .ace_meta.ace_tag,
    .ace_string.ace_regexp,
    .ace_variable {
      color: #ff7878;
    }

    .ace_comment {
      color: #717171;
    }
  }
",
    "button": [
      "
      &.btn-danger {
        background-color: #FF0000;
        border-color: #ff3535;
        color: rgb(255,249,249);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #ee262b;
          border-color: #ee3e41;
          color: #eee9ea;
        }

        &.active {
          background-color: #ff4a4a;
          border-color: #ff5b5b;
          color: rgb(255,249,249);

          &:hover {
            background-color: #ee4e51;
            border-color: #ee5c5e;
            color: #eee9ea;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #ff6969;
          border-color: #ff5b5b;
          color: rgb(255,250,250);

          &:hover {
            background-color: #ff6969;
            border-color: #ff5b5b;
            color: rgb(255,250,250);
          }
        }
      }
",
      "
      &.btn-default {
        background-color: #eddcdd;
        border-color: #e8d8d9;
        color: rgb(75,70,70);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #ddced0;
          border-color: #d9cbcd;
          color: #4e4b4e;
        }

        &.active {
          background-color: #e3d3d5;
          border-color: #ddced0;
          color: rgb(51,47,48);

          &:hover {
            background-color: #d4c6c9;
            border-color: #cfc2c5;
            color: #3b3a3e;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #d8cacc;
          border-color: #ddced0;
          color: rgb(84,78,79);

          &:hover {
            background-color: #d8cacc;
            border-color: #ddced0;
            color: rgb(84,78,79);
          }
        }
      }
",
      "
      &.btn-info {
        background-color: #0000FF;
        border-color: #3935fe;
        color: rgb(235,235,255);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #2426ef;
          border-color: #3f3eee;
          color: #dcdcef;
        }

        &.active {
          background-color: #514afd;
          border-color: #635bfc;
          color: rgb(249,249,255);

          &:hover {
            background-color: #534eed;
            border-color: #625cec;
            color: #e8e9ef;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #7269fb;
          border-color: #635bfc;
          color: rgb(250,250,255);

          &:hover {
            background-color: #7269fb;
            border-color: #635bfc;
            color: rgb(250,250,255);
          }
        }
      }
",
      "
      &.btn-link {
        background-color: rgba(255, 255, 255, 0);
        border-color: rgba(255, 255, 255, 0);
        color: #8cb5ea;
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: transparent;
          border-color: transparent;
          color: #5b85b8;
        }

        &.active {
          background-color: rgba(255, 255, 255, 0);
          border-color: rgba(255, 255, 255, 0);
          color: #5b85b8;

          &:hover {
            background-color: rgba(255, 255, 255, 0);
            border-color: transparent;
            color: #5b85b8;
          }
        }

        &[disabled],
        &.disabled {
          background-color: rgba(255, 255, 255, 0);
          border-color: rgba(255, 255, 255, 0);
          color: #8cb5ea;

          &:hover {
            background-color: rgba(255, 255, 255, 0);
            border-color: rgba(255, 255, 255, 0);
            color: #8cb5ea;
          }
        }
      }
",
      "
      &.btn-primary {
        background-color: #800080;
        border-color: #893587;
        color: rgb(230,221,230);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #7b267e;
          border-color: #833e84;
          color: #d7cfd8;
        }

        &.active {
          background-color: #924a8e;
          border-color: #9a5b95;
          color: rgb(251,249,251);

          &:hover {
            background-color: #8b4e8a;
            border-color: #925c90;
            color: #eae9eb;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #a2699b;
          border-color: #9a5b95;
          color: rgb(251,250,251);

          &:hover {
            background-color: #a2699b;
            border-color: #9a5b95;
            color: rgb(251,250,251);
          }
        }
      }
",
      "
      &.btn-success {
        background-color: #008000;
        border-color: #398735;
        color: rgb(249,250,249);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #247c2b;
          border-color: #3f8241;
          color: #e8eaea;
        }

        &.active {
          background-color: #518e4a;
          border-color: #63955b;
          color: rgb(249,251,249);

          &:hover {
            background-color: #538851;
            border-color: #628f5e;
            color: #e8ebea;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #729b69;
          border-color: #63955b;
          color: rgb(250,251,250);

          &:hover {
            background-color: #729b69;
            border-color: #63955b;
            color: rgb(250,251,250);
          }
        }
      }
",
      "
      &.btn-warning {
        background-color: #FFFF00;
        border-color: #f9fa19;
        color: rgb(81,81,0);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #eeee2b;
          border-color: #e8ea31;
          color: #53542b;
        }

        &.active {
          background-color: #f4f423;
          border-color: #eeee2b;
          color: rgb(77,77,11);

          &:hover {
            background-color: #e4e436;
            border-color: #dedf3b;
            color: #4f512d;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #e8e832;
          border-color: #eeee2b;
          color: rgb(90,90,19);

          &:hover {
            background-color: #e8e832;
            border-color: #eeee2b;
            color: rgb(90,90,19);
          }
        }
      }
",
      "
      &.btn-gray {
        background-color: #eaeaeb;
        border-color: #e5e5e6;
        color: rgb(74,74,74);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #dbdbdd;
          border-color: #d6d7d8;
          color: #4d4e51;
        }

        &.active {
          background-color: #e0e0e2;
          border-color: #dbdbdd;
          color: rgb(71,71,71);

          &:hover {
            background-color: #d2d2d5;
            border-color: #cdced0;
            color: #4b4c4f;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #d5d6d8;
          border-color: #dbdbdd;
          color: rgb(82,83,84);

          &:hover {
            background-color: #d5d6d8;
            border-color: #dbdbdd;
            color: rgb(82,83,84);
          }
        }
      }
",
    ],
  },
  "fonts": {
    "family": {
      "body": ""Source Sans Pro", "Helvetica Neue", Helvetica, Arial, sans-serif",
      "monospace": ""Ubuntu Mono", Menlo, Monaco, Consolas, "Courier New", monospace",
      "navigation": ""DM Sans", "Helvetica Neue", Helvetica, Arial, sans-serif",
    },
    "lineHeight": {
      "body": "1.24px",
    },
    "size": {
      "body": "1.000rem",
      "extraLarge": "1.383rem",
      "h1": "1.575rem",
      "h2": "1.296rem",
      "h3": "1.215rem",
