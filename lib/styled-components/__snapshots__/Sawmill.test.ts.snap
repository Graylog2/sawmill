        &:hover {
          background-color: #ddced0;
          border-color: #d9cbcd;
          color: #4e4b4e;
        }

        &.active {
          background-color: #e3d3d5;
          border-color: #ddced0;
          color: rgb(51,47,48);

          &:hover {
            background-color: #d4c6c9;
            border-color: #cfc2c5;
            color: #3b3a3e;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #d8cacc;
          border-color: #ddced0;
          color: rgb(84,78,79);

          &:hover {
            background-color: #d8cacc;
            border-color: #ddced0;
            color: rgb(84,78,79);
          }
        }
      }
    ",
      "
      &.btn-info {
        background-color: #0000FF;
        border-color: #3935fe;
        color: rgb(235,235,255);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #2426ef;
          border-color: #3f3eee;
          color: #dcdcef;
        }

        &.active {
          background-color: #514afd;
          border-color: #635bfc;
          color: rgb(249,249,255);

          &:hover {
            background-color: #534eed;
            border-color: #625cec;
            color: #e8e9ef;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #7269fb;
          border-color: #635bfc;
          color: rgb(250,250,255);

          &:hover {
            background-color: #7269fb;
            border-color: #635bfc;
            color: rgb(250,250,255);
          }
        }
      }
    ",
      "
      &.btn-link {
        background-color: rgba(255, 255, 255, 0);
        border-color: rgba(255, 255, 255, 0);
        color: var(--color-global-link);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: transparent;
          border-color: transparent;
          color: var(--color-global-linkHover);
        }

        &.active {
          background-color: rgba(255, 255, 255, 0);
          border-color: rgba(255, 255, 255, 0);
          color: var(--color-global-linkHover);

          &:hover {
            background-color: rgba(255, 255, 255, 0);
            border-color: transparent;
            color: var(--color-global-linkHover);
          }
        }

        &[disabled],
        &.disabled {
          background-color: rgba(255, 255, 255, 0);
          border-color: rgba(255, 255, 255, 0);
          color: var(--color-global-link);

          &:hover {
            background-color: rgba(255, 255, 255, 0);
            border-color: rgba(255, 255, 255, 0);
            color: var(--color-global-link);
          }
        }
      }
    ",
      "
