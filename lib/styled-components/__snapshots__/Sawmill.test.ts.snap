  "components": {
    "aceEditor": "
 .ace_editor {
    border: 1px solid #C1C7DC !important;
    border-radius: 0;
  }

  .ace-graylog {
    background-color: #0b42ff;
    color: #2c2c2c;

    &.ace_multiselect .ace_selection.ace_start {
      box-shadow: 0 0 3px 0 #0b42ff;
    }

    .ace_gutter {
      background: #bbbbbb;
      color: #2c2c2c;
    }

    .ace_print-margin {
      width: 1px;
      background: #e2e2e2;
    }

    .ace_cursor {
      border-color: #5c6370;
    }

    .ace_marker-layer {
      .ace_selection {
        background: Highlight;
      }

      .ace_step {
        background: rgb(255 255 0);
      }

      .ace_bracket {
        margin: -1px 0 0 -1px;
        border: 1px solid #b6b9c2;
      }

      .ace_selected-word {
        border: 1px solid #9ea2ad;
        background: transparent;
      }

      .ace_active-line {
        background: #e2e2e2;
      }
    }

    .ace_gutter-active-line {
      background-color: #e2e2e2;
    }

    .ace_invisible {
      color: #b6b9c2;
    }

    .ace_keyword,
    .ace_meta,
    .ace_storage,
    .ace_storage.ace_type,
    .ace_support.ace_type {
      color: #8cb5ea;
    }

    .ace_keyword.ace_operator {
      color: #000088;
    }

    .ace_constant.ace_character,
    .ace_constant.ace_language,
    .ace_constant.ace_numeric,
    .ace_keyword.ace_other.ace_unit,
    .ace_support.ace_constant,
    .ace_variable.ace_parameter {
      color: #440044;
    }

    .ace_constant.ace_other {
      color: #444444;
    }

    .ace_invalid {
      color: #ffebeb;
      background-color: #FF0000;
    }

    .ace_invalid.ace_deprecated {
      color: #ffebeb;
      background-color: #710071;
    }

    .ace_fold {
      background-color: #0000e1;
      border-color: #2c2c2c;
    }

    .ace_entity.ace_name.ace_function,
    .ace_support.ace_function,
    .ace_variable {
      color: #0000e1;
    }

    .ace_support.ace_class,
    .ace_support.ace_type {
      color: #888800;
    }

    .ace_heading,
    .ace_markup.ace_heading,
    .ace_string {
      color: #004400;
    }

    .ace_entity.ace_name.ace_tag,
    .ace_entity.ace_other.ace_attribute-name,
    .ace_meta.ace_tag,
    .ace_string.ace_regexp,
    .ace_variable {
      color: #FF0000;
    }

    .ace_comment {
      color: rgba(92,99,112,0.6);
    }

    .ace_tooltip {
      background-color: #89a4ff;
      padding: 4px;
      padding-left: 0;
      line-height: 1.5;
      
      .ace_icon {
        margin-right: 3px;
      }
    }
  }
",
  },
  "fonts": {
    "family": {
      "body": ""Source Sans Pro", "Helvetica Neue", Helvetica, Arial, sans-serif",
      "monospace": ""Ubuntu Mono", Menlo, Monaco, Consolas, "Courier New", monospace",
      "navigation": ""DM Sans", "Helvetica Neue", Helvetica, Arial, sans-serif",
    },
    "lineHeight": {
      "body": "1.24px",
    },
    "size": {
      "body": "1.000rem",
      "extraLarge": "1.383rem",
      "h1": "1.575rem",
      "h2": "1.296rem",
      "h3": "1.215rem",
