  "components": {
    "aceEditor": "
  .ace_editor {
    border: 1px solid var(--colors-gray-80);
    border-radius: 5px;
  }
  
  .ace-graylog {
    background-color: var(--colors-global-contentBackground);
    color: var(--colors-global-contentBackground);
  
    &.ace_multiselect .ace_selection.ace_start {
      box-shadow: 0 0 3px 0 var(--colors-global-contentBackground);
    }
  
    .ace_gutter {
      background: var(--colors-variant-lightest-default);
      color: var(--colors-global-contentBackground);
    }
  
    .ace_print-margin {
      width: 1px;
      background: var(--colors-variant-lightest-default);
    }
  
    .ace_cursor {
      color: var(--colors-variant-light-default);
    }
  
    .ace_marker-layer {
      .ace_selection {
        background: var(--colors-gray-70);
      }
  
      .ace_step {
        background: rgb(255, 255, 0);
      }
  
      .ace_bracket {
        margin: -1px 0 0 -1px;
        border: 1px solid var(--colors-gray-70);
      }
  
      .ace_selected-word {
        border: 1px solid #b7afb4;
      }
  
      .ace_active-line {
        background: var(--colors-variant-lighter-default);
      }
    }
  
    .ace_gutter-active-line {
      background-color: var(--colors-variant-lighter-default);
    }
  
    .ace_invisible {
      color: var(--colors-gray-70);
    }
  
    .ace_keyword,
    .ace_meta,
    .ace_storage,
    .ace_storage.ace_type,
    .ace_support.ace_type {
      color: #8cb5ea;
    }
  
    .ace_keyword.ace_operator {
      color: #0000ab;
    }
  
    .ace_constant.ace_character,
    .ace_constant.ace_language,
    .ace_constant.ace_numeric,
    .ace_keyword.ace_other.ace_unit,
    .ace_support.ace_constant,
    .ace_variable.ace_parameter {
      color: var(--colors-variant-darker-primary);
    }
  
    .ace_constant.ace_other {
      color: var(--colors-variant-darker-default);
    }
  
    .ace_invalid {
      color: var(--colors-global-altText);
      background-color: #ff7878;
    }
  
    .ace_invalid.ace_deprecated {
      color: var(--colors-global-altText);
      background-color: var(--colors-variant-primary);
    }
  
    .ace_fold {
      background-color: #0000FF;
      border-color: var(--colors-variant-darkest-default);
    }
  
    .ace_entity.ace_name.ace_function,
    .ace_support.ace_function,
    .ace_variable {
      color: #0000FF;
    }
  
    .ace_support.ace_class,
    .ace_support.ace_type {
      color: #abab00;
    }
  
    .ace_heading,
    .ace_markup.ace_heading,
    .ace_string {
      color: #005600;
    }
  
    .ace_entity.ace_name.ace_tag,
    .ace_entity.ace_other.ace_attribute-name,
    .ace_meta.ace_tag,
    .ace_string.ace_regexp,
    .ace_variable {
      color: #ff7878;
    }
  
    .ace_comment {
      color: #717171;
    }
  }
",
    "button": [
      "
      &.btn-danger {
        background-color: #FF0000;
        border-color: #ff3535;
        color: rgb(255,249,249);
        transition: background-color 150ms ease-in-out,
          border 150ms ease-in-out,
          color 150ms ease-in-out;

        &:hover {
          background-color: #ee262b;
          border-color: #ee3e41;
          color: #eee9ea;
        }

        &.active {
          background-color: #ff4a4a;
          border-color: #ff5b5b;
          color: rgb(255,249,249);

          &:hover {
            background-color: #ee4e51;
            border-color: #ee5c5e;
            color: #eee9ea;
          }
        }

        &[disabled],
        &.disabled {
          background-color: #ff6969;
          border-color: #ff5b5b;
          color: rgb(255,250,250);

          &:hover {
            background-color: #ff6969;
            border-color: #ff5b5b;
            color: rgb(255,250,250);
          }
        }
      }
    ",
      "
      &.btn-default {
        background-color: #eddcdd;
