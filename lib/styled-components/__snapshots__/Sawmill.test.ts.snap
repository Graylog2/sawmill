  "components": {
    "aceEditor": "
 .ace_editor {
    border: 1px solid rgba(154,154,154,0.74) !important;
    border-radius: 0;
  }

  .ace-graylog {
    background-color: #0b42ff;
    color: #e6e6e6;

    &.ace_multiselect .ace_selection.ace_start {
      box-shadow: 0 0 3px 0 #0b42ff;
    }

    .ace_gutter {
      background: #404040;
      color: #e6e6e6;
    }

    .ace_print-margin {
      width: 1px;
      background: #1d1d1d;
    }

    .ace_cursor {
      border-color: #5c6370;
    }

    .ace_marker-layer {
      .ace_selection {
        background: Highlight;
      }

      .ace_step {
        background: rgb(255 255 0);
      }

      .ace_bracket {
        margin: -1px 0 0 -1px;
        border: 1px solid #b0b0b0;
      }

      .ace_selected-word {
        border: 1px solid #bdbdbd;
        background: transparent;
      }

      .ace_active-line {
        background: #1d1d1d;
      }
    }

    .ace_gutter-active-line {
      background-color: #1d1d1d;
    }

    .ace_invisible {
      color: #b0b0b0;
    }

    .ace_keyword,
    .ace_meta,
    .ace_storage,
    .ace_storage.ace_type,
    .ace_support.ace_type {
      color: #8cb5ea;
    }

    .ace_keyword.ace_operator {
      color: #9797ff;
    }

    .ace_constant.ace_character,
    .ace_constant.ace_language,
    .ace_constant.ace_numeric,
    .ace_keyword.ace_other.ace_unit,
    .ace_support.ace_constant,
    .ace_variable.ace_parameter {
      color: #b797b7;
    }

    .ace_constant.ace_other {
      color: #b7b7b7;
    }

    .ace_invalid {
      color: #ffebeb;
      background-color: #ce0000;
    }

    .ace_invalid.ace_deprecated {
      color: #ffebeb;
      background-color: #760076;
    }

    .ace_fold {
      background-color: #0000eb;
      border-color: #e6e6e6;
    }

    .ace_entity.ace_name.ace_function,
    .ace_support.ace_function,
    .ace_variable {
      color: #0000eb;
    }

    .ace_support.ace_class,
    .ace_support.ace_type {
      color: #ffff97;
    }

    .ace_heading,
    .ace_markup.ace_heading,
    .ace_string {
      color: #97b797;
    }

    .ace_entity.ace_name.ace_tag,
    .ace_entity.ace_other.ace_attribute-name,
    .ace_meta.ace_tag,
    .ace_string.ace_regexp,
    .ace_variable {
      color: #ce0000;
    }

    .ace_comment {
      color: rgba(92,99,112,0.6);
    }

    .ace_tooltip {
      background-color: #89a4ff;
      padding: 4px;
      padding-left: 0;
      line-height: 1.5;
      
      .ace_icon {
        margin-right: 3px;
      }
    }
  }
",
