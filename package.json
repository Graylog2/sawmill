{
  "name": "@graylog/sawmill",
  "version": "1.0.5",
  "description": "Graylog's Design System and Component Library",
  "main": "dist/index.js",
  "author": "Graylog <engineering@graylog.com>",
  "license": "MIT",
  "types": "types.d.ts",
  "scripts": {
    "lint": "eslint lib --fix",
    "build": "tsc",
    "generate-themes": "ts-node lib/scripts/generateThemes.ts",
    "test": "jest"
  },
  "files": ["dist", "types.d.ts"],
  "exports": {
    ".": "./dist/index.js",
    "./styled-components": "./dist/styled-components/Sawmill.js",
    "./mantine": "./dist/mantine/Sawmill.js"
  },
  "dependencies": {
    "@openfonts/dm-sans_latin": "^1.0.2",
    "@openfonts/source-sans-pro_latin": "^1.44.2",
    "@openfonts/ubuntu-mono_latin": "^1.44.1",
    "chroma-js": "^2.1.2",
    "lodash": "^4.17.21"
  },
  "jest": {
    "preset": "ts-jest",
    "testPathIgnorePatterns": [
      "dist/*"
    ],
    "transform": {
      "\\.css$": "jest-transform-css"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@openfonts)"
    ]
  },
  "devDependencies": {
    "@types/chroma-js": "^2.1.3",
    "@types/jest": "^29.5.4",
    "@types/lodash": "^4.14.197",
    "@typescript-eslint/eslint-plugin": "4.33.0",
    "@typescript-eslint/parser": "^4.31.1",
    "eslint": "7.32.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jest": "^27.2.3",
    "jest": "29.5.0",
    "jest-transform-css": "^6.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "5.0.4"
  },
  "peerDependencies": {
    "chroma-js": "^2.1.2",
    "react": ">=16.0.0"
  }
}
