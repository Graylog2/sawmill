{
  "name": "@graylog/sawmill",
  "version": "1.0.5",
  "description": "Graylog's Design System and Component Library",
  "main": "dist/index.js",
  "author": "Graylog <engineering@graylog.com>",
  "license": "MIT",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "lint": "eslint lib --fix",
    "tsc": "tsc",
    "build": "tsc && babel lib --out-dir dist --extensions \".ts\"",
    "generate-themes": "ts-node lib/scripts/generateThemes.ts",
    "test": "jest"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@openfonts/dm-sans_latin": "^1.0.2",
    "@openfonts/source-sans-pro_latin": "^1.44.2",
    "@openfonts/ubuntu-mono_latin": "^1.44.1",
    "chroma-js": "^2.1.2",
    "lodash": "^4.17.21",
    "prop-types": "^15.7.2"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "dist/*"
    ],
    "transform": {
      "\\.[jt]sx?$": "babel-jest",
      "\\.css$": "jest-transform-css"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@openfonts)"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^7.15.4",
    "@babel/core": "^7.15.5",
    "@babel/eslint-parser": "7.21.3",
    "@babel/eslint-plugin": "^7.14.5",
    "@babel/plugin-transform-runtime": "^7.21.4",
    "@babel/preset-env": "^7.15.6",
    "@babel/preset-typescript": "^7.15.0",
    "@types/chroma-js": "^2.1.3",
    "@types/jest": "^29.5.0",
    "@types/lodash": "^4.14.197",
    "@types/node": "^18.15.11",
    "@types/prop-types": "^15.7.4",
    "@typescript-eslint/eslint-plugin": "4.33.0",
    "@typescript-eslint/parser": "^4.31.1",
    "eslint": "7.32.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.24.2",
    "eslint-plugin-jest": "^27.2.3",
    "jest": "29.5.0",
    "jest-transform-css": "^6.0.1",
    "ts-node": "^10.9.1",
    "typescript": "5.0.4"
  },
  "peerDependencies": {
    "chroma-js": "^2.1.2",
    "react": ">=16.0.0"
  }
}
