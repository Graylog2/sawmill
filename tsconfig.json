{
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs",
    }
  },
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./lib",
    "declaration": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "resolveJsonModule": true,
    "strict": true,
    "target": "es5",
  },
  "include": [
    "./lib/index.ts",
    "./lib/fonts.ts",
    "./lib/styled-components/Sawmill.ts",
    "./lib/mantine/Sawmill.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
